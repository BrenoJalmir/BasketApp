<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0B1A"
    android:padding="12dp"
    tools:context="com.seu.pacote">


    <ImageView 
        android:id="@+id/logoTopo" 
        android:layout_width="220dp" 
        android:layout_height="220dp" 
        android:layout_alignParentTop="true" 
        android:layout_centerHorizontal="true" 
        android:layout_marginTop="12dp" 
        android:adjustViewBounds="true" 
        android:contentDescription="@string/app_name" 
        android:src="@drawable/logo_dungeons_hoops" 
    />

    <LinearLayout
        android:id="@+id/painelPrincipal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/logoTopo"
        android:layout_marginTop="12dp"
        android:layout_above="@id/reiniciarPartida"
        android:layout_marginBottom="16dp"
        android:background="#1B1530"
        android:orientation="horizontal"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#241B3D"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/timeA"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:gravity="center"
                android:padding="12dp"
                android:text="Magos"
                android:textAllCaps="true"
                android:textColor="#F6D36B"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/placarTimeA"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="#120D22"
                android:fontFamily="serif"
                android:gravity="center"
                android:padding="12dp"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="56sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/tresPontosA"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                android:backgroundTint="#6A1B9A"
                android:text="+3 PONTOS"
                android:textColor="#F8E7A1"
                android:textStyle="bold" />

            <Button
                android:id="@+id/doisPontosA"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                android:backgroundTint="#8E24AA"
                android:text="+2 PONTOS"
                android:textColor="#F8E7A1"
                android:textStyle="bold" />

            <Button
                android:id="@+id/tiroLivreA"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                android:backgroundTint="#3949AB"
                android:text="TIRO LIVRE"
                android:textColor="#F8E7A1"
                android:textStyle="bold" />

        </LinearLayout>

        <View
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="10dp"
            android:background="#D4AF37" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#241B3D"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/timeB"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:gravity="center"
                android:padding="12dp"
                android:text="Orcs"
                android:textAllCaps="true"
                android:textColor="#F6D36B"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/placarTimeB"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="#120D22"
                android:fontFamily="serif"
                android:gravity="center"
                android:padding="12dp"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="56sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/tresPontosB"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                android:backgroundTint="#2E7D32"
                android:text="+3 PONTOS"
                android:textColor="#F8E7A1"
                android:textStyle="bold" />

            <Button
                android:id="@+id/doisPontosB"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                android:backgroundTint="#388E3C"
                android:text="+2 PONTOS"
                android:textColor="#F8E7A1"
                android:textStyle="bold" />

            <Button
                android:id="@+id/tiroLivreB"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                android:backgroundTint="#00897B"
                android:text="TIRO LIVRE"
                android:textColor="#F8E7A1"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <Button
        android:id="@+id/reiniciarPartida"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_margin="20dp"
        android:backgroundTint="#B71C1C"
        android:text="REINICIAR PARTIDA"
        android:textColor="#FFF3E0"
        android:textStyle="bold" />

</RelativeLayout>